{
  "name": "helm-server",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/helm-server/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "platform": "node",
        "outputPath": "dist/apps/helm-server",
        "format": ["cjs"],
        "bundle": true,
        "thirdParty": false,
        "tsPaths": true,
        "main": "apps/helm-server/src/main.ts",
        "tsConfig": "apps/helm-server/tsconfig.app.json",
        "assets": ["apps/helm-server/src/assets"],
        "generatePackageJson": true,
        "external": [
          "express",
          "cors",
          "ws",
          "uuid",
          "node:path",
          "node:http",
          "node:url",
          "node:fs",
          "node:stream"
        ],
        "esbuildOptions": {
          "sourcemap": false,
          "outExtension": { ".js": ".js" }
        }
      },
      "configurations": {
        "development": {
          "esbuildOptions": {
            "sourcemap": true,
            "outExtension": { ".js": ".js" }
          }
        },
        "production": {
          "esbuildOptions": {
            "sourcemap": false,
            "outExtension": { ".js": ".js" }
          }
        }
      }
    },
    "prune-lockfile": {
      "dependsOn": ["build"],
      "cache": true,
      "executor": "@nx/js:prune-lockfile",
      "outputs": [
        "{workspaceRoot}/dist/apps/helm-server/package.json",
        "{workspaceRoot}/dist/apps/helm-server/pnpm-lock.yaml"
      ],
      "options": {
        "buildTarget": "build"
      }
    },
    "copy-workspace-modules": {
      "dependsOn": ["build"],
      "cache": true,
      "outputs": ["{workspaceRoot}/dist/apps/helm-server/workspace_modules"],
      "executor": "@nx/js:copy-workspace-modules",
      "options": {
        "buildTarget": "build"
      }
    },
    "prune": {
      "dependsOn": ["prune-lockfile", "copy-workspace-modules"],
      "executor": "nx:noop"
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "helm-server:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "helm-server:build:development"
        },
        "production": {
          "buildTarget": "helm-server:build:production"
        }
      }
    }
  },
  "tags": []
}
