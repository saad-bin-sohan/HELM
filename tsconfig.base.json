{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "baseUrl": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "@helm/models":      ["apps/helm-ui/src/app/core/models/index.ts"],
      "@helm/core/*":      ["apps/helm-ui/src/app/core/*"],
      "@helm/shared/*":    ["apps/helm-ui/src/app/shared/*"],
      "@helm/features/*":  ["apps/helm-ui/src/app/features/*"],
      "@helm/env":         ["apps/helm-ui/src/environments/environment.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
